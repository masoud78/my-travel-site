# ============================================================
# ریوان سفر — Environment Variables (Example)
# ============================================================
#
# پروژه روی PostgreSQL کار می‌کند. Supabase = PostgreSQL مدیریت‌شده.
# رشته اتصال Postgres را از:
#   Supabase Dashboard → Project Settings → Database → Connection string (URI)
# کپی کنید. شبیه این است:
#   postgresql://postgres:[PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# روش ۱ (توصیه‌شده):
DATABASE_URL="postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.rtrdjphgqhwugesnuobx.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.rtrdjphgqhwugesnuobx.supabase.co:5432/postgres?sslmode=require"
#
# روش ۲ (اختیاری — نام‌گذاری Supabase):
# SUPABASE_DB_URL="postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.rtrdjphgqhwugesnuobx.supabase.co:5432/postgres?sslmode=require"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_SITE_NAME="ریوان سفر"
